# ═══════════════════════════════════════════════════════════
# Covenant Trader — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
# ═══════════════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────────────
# Find both in: Supabase Dashboard → Settings → API

# Server-side only (service-role key — NEVER expose to browser)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...REPLACE_ME

# Client-side safe (anon key — public, only reads/writes within RLS rules)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...REPLACE_ME

# ── App ─────────────────────────────────────────────────────
# The exact domain your app is deployed to (no trailing slash)
APP_URL=https://your-app.vercel.app
NODE_ENV=production

# ── CSRF Protection ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
CSRF_SECRET=replace_with_64_random_hex_chars

# ── Cloudflare Turnstile CAPTCHA ────────────────────────────
# Get these at: https://dash.cloudflare.com → Turnstile
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxxxxxx   # shown in browser
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxxxxxx      # server-side only

# ── Supabase Auth configuration (set in Dashboard, not env) ─
# Dashboard → Authentication → Settings:
#   JWT expiry           = 900   (15 minutes)
#   Refresh token expiry = 604800 (7 days)
#   Refresh token rotation  = ENABLED
#   Reuse interval          = 0
#   Password minimum length = 12
